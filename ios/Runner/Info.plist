<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

	<!-- ============================================================ -->
	<!-- LOCATION PERMISSIONS                                          -->
	<!-- ============================================================ -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>BFS Guard Portal needs your location to track your position during active security shifts and verify checkpoint visits.</string>

	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>BFS Guard Portal requires continuous location access to monitor your patrol routes and ensure your safety during security shifts, even when the app is in the background.</string>

	<!-- Legacy iOS 10 and below -->
	<key>NSLocationAlwaysUsageDescription</key>
	<string>Location access is essential for tracking guard patrol routes and ensuring safety during security shifts.</string>

	<!-- ============================================================ -->
	<!-- CAMERA                                                        -->
	<!-- ============================================================ -->
	<key>NSCameraUsageDescription</key>
	<string>BFS Guard Portal needs camera access to capture photos and videos for incident reports and counseling statements.</string>

	<!-- ============================================================ -->
	<!-- PHOTO LIBRARY                                                 -->
	<!-- ============================================================ -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>BFS Guard Portal needs access to your photo library to attach images to incident reports and counseling statements.</string>

	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>BFS Guard Portal needs permission to save report photos to your photo library.</string>

	<!-- ============================================================ -->
	<!-- MICROPHONE                                                    -->
	<!-- ============================================================ -->
	<key>NSMicrophoneUsageDescription</key>
	<string>BFS Guard Portal needs microphone access to record videos with audio for incident reports and counseling statements.</string>

	<!-- ============================================================ -->
	<!-- NFC                                                           -->
	<!-- ============================================================ -->
	<key>NFCReaderUsageDescription</key>
	<string>BFS Guard Portal uses NFC to scan and assign checkpoint tags during security patrols.</string>

	<key>com.apple.developer.nfc.readersession.formats</key>
	<array>
		<string>TAG</string>
	</array>

	<!-- ============================================================ -->
	<!-- NOTIFICATIONS (legacy key for older iOS)                     -->
	<!-- ============================================================ -->
	<key>NSUserNotificationUsageDescription</key>
	<string>BFS Guard Portal sends important notifications for shift assignments, safety alerts, and real-time updates.</string>

	<!-- ============================================================ -->
	<!-- BUNDLE CONFIGURATION                                          -->
	<!-- ============================================================ -->
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>

	<key>CFBundleDisplayName</key>
	<string>BFS Guard Portal</string>

	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>

	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>

	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<key>CFBundleName</key>
	<string>crossplatformblackfabric</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>

	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>

	<key>CFBundleSignature</key>
	<string>????</string>

	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- ============================================================ -->
	<!-- UI CONFIGURATION                                              -->
	<!-- ============================================================ -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<key>UIMainStoryboardFile</key>
	<string>Main</string>

	<!-- Portrait only — security app, no landscape needed -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- ============================================================ -->
	<!-- BACKGROUND MODES                                              -->
	<!-- ============================================================ -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>

	<!-- ============================================================ -->
	<!-- PERFORMANCE                                                   -->
	<!-- ============================================================ -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

</dict>
</plist>
